<section class="testimonials-wrap" id="testimonials">
  <header>
    <h1 data-translate="about.reviews_title">Reviews</h1>
    <h3 data-translate="about.reviews_subtitle">Feedback from clients and teams I have worked with.</h3>
  </header>

  <div class="testimonials-carousel">
    <button
      class="testimonials-nav prev"
      id="testimonialsPrev"
      type="button"
      aria-label="Previous reviews"
      data-translate-aria-label="about.reviews_prev_aria"
    >&#8249;</button>

    <div class="testimonials-viewport">
      <div class="testimonials-track" id="testimonialsList" aria-live="polite">
        <!-- Populated from /assets/data/testimonials.json -->
      </div>
    </div>

    <button
      class="testimonials-nav next"
      id="testimonialsNext"
      type="button"
      aria-label="Next reviews"
      data-translate-aria-label="about.reviews_next_aria"
    >&#8250;</button>
  </div>
</section>
