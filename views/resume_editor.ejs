<!-- @deprecated Legacy resume/CV template. -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link rel="shortcut icon" type="image/x-icon" href="/assets/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title data-translate="resume.editor_title">Resume Editor</title>
    <link rel="stylesheet" href="/assets/css/resume.css">
    <link rel="stylesheet" href="/assets/css/resume-preview.css">
    <script src="/assets/javascript/translations.js"></script>
    <script src="/assets/javascript/api.js"></script>
    <script src="/assets/javascript/utils.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.9.2/html2pdf.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.14.0/Sortable.min.js"></script>
</head>
<body>
    <div class="container">
        <div id="inputSection" class="input-section panel left">
            <h2>Resume Editor</h2>

            <div class="section">
                <%- include('partials/cv/cv_general_info') %>
            </div>
    
            <div class="section">
                <h3 data-translate="resume.work_experience">Work Experience</h3>
                <input type="hidden" id="workExperienceId">
                <%- include('partials/cv/cv_work_experience') %>
            </div>

            <div class="section">
                <h3 data-translate="resume.education">Education</h3>
                <input type="hidden" id="educationId">
                <%- include('partials/cv/cv_education') %>
            </div>

            <div class="section">
                <h3 data-translate="resume.projects">Projects</h3>
                <input type="hidden" id="projectId">
                <%- include('partials/cv/cv_projects') %>
            </div>
            
            <button type="button" id="saveResume" data-translate="resume.save_resume">Save Resume</button>
            <button id="downloadPDF" data-translate="resume.download_pdf">Download as PDF</button>

        </div>
        <div class="divider"></div>
        <div id="previewSection" class="preview-section panel right">
            <h2 data-translate="resume.preview">Preview</h2>
            <div id="preview">
                <%- include('partials/cv/cv_preview') %>
            </div>
        </div>
    </div>

    <script src="/assets/javascript/resume.js"></script>
</body>
</html>

