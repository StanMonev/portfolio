<!DOCTYPE html>
<html lang="en" data-theme="dark">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <link rel="shortcut icon" type="image/x-icon" href="/assets/favicon.ico" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Software Engineer Stanimir Monev builds scalable web, Shopify, and AI-powered solutions with modern architecture. View projects, experience, and contact details.">
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
  <link rel="stylesheet" type="text/css" href="/assets/font.css">
  <link rel="stylesheet" type="text/css" href="/assets/css/style.css">
  <link rel="preload" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" as="style" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous"></noscript>
  <script defer src="<%= jsAsset('typewriter.js') %>"></script>
  <script defer src="<%= jsAsset('api.js') %>"></script>
  <script defer src="<%= jsAsset('utils.js') %>"></script>
  <script defer src="<%= jsAsset('cookies.js') %>"></script>
  <script defer src="<%= jsAsset('index.js') %>"></script>
  <script defer src="<%= jsAsset('translations.js') %>"></script>
  <title>StanimirMonevWorks</title>
</head>

<body>
  <div>
    <%- include('partials/messageBox', {css: 'success'}); %>
    <%- include('partials/messageBox', {css: 'error'}); %>
  </div>
  <div class="main-container">
    <%- include('partials/header'); %>
    <canvas class="matrix"></canvas>
    <main>
      <div id="content">
        <div id="home" class="section">
          <div class="section-container">
            <%- include('partials/welcome'); %>
          </div>
        </div>
        <div id="about" class="section">
          <div class="section-container">
            <%- include('partials/about'); %>
            <%- include('partials/skills', { skills: skills }); %>
            <%- include('partials/testimonials'); %>
          </div>
          <div id="resumeContainer"></div>
        </div>
        <div id="contact" class="section">
          <div class="section-container">
            <%- include('partials/contact'); %>
          </div>
        </div>
      </div>
    </main>
    <footer class="footer">
      <a id="copyright" class="modal-link link" href="/copyright-content"><span>Copyright © <%= new Date().getFullYear() %></span></a>
      <span>Made with &#10084;&#65039; by Stanimir Monev</span>
      <span>
        <%- include('partials/socialMedia', {id:'contacts', css:'social-media-icons-footer', section:'footer'}); %>
      </span>
    </footer>
  </div>

  <%- include('partials/cookiesBanner'); %>
  <%- include('partials/modal'); %>
    
  <script defer src="<%= jsAsset('testimonials.js') %>"></script>
  <script defer src="<%= jsAsset('resumeDownload.js') %>"></script>
</body>

</html>
